# Entorno virtual
.venv/

# Datos de sesiones (generados por el juego)
data/
data_test/

# Salidas de análisis confound_floor (todos los directorios out_*)
analysis/confound_floor/out/
analysis/confound_floor/out_*/

# Archivos de datos grandes generados por los análisis
*.parquet
*.csv

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.egg-info/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Resultados descargados de corridas Colab (regenerables; incluye snapshots de scripts y outputs)
colab/results_colab/
colab/results_colab_*/

# Documentos de trabajo de sesión (no forman parte del repo)
RESUMEN_sesion_*.md

# Archivos temporales de prueba
tmp_test.py
results_colab.zip
